CompileFlags:
  # Prefer compile_commands.json (generated by CMake, build/compile_commands.json)
  # for accurate per-platform flags -- e.g. -m32 on Linux/Windows, none on macOS.
  # These are only a fallback for files outside that database.
  Add:
    - -std=c99
    - -DCTR_NATIVE
    - -DUSE_EXTENDED_PRIM_POINTERS=0
    - -DUSE_PCDRV
    - -DCTR_INTERNAL
    - -Iinclude
    - -Iexternals/PsyCross/include
    - -Iexternals/PsyCross
    - -Iexternals/SDL/include
    - -Iexternals/openal-soft/include
